{
  "name": "jarvis-avatar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Real-time 3D neon-blue Jarvis avatar overlay for the mcp-voice-hooks browser UI.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts && node scripts/build-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "e2e:install": "playwright install chromium",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "vendor:three": "node scripts/vendor-three.mjs",
    "inject": "node scripts/inject.mjs",
    "inject:revert": "node scripts/inject.mjs --revert"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.8.0",
    "@types/three": "^0.128.0",
    "eslint": "^10.5.0",
    "globals": "^15.11.0",
    "happy-dom": "^20.10.6",
    "three": "0.128.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
