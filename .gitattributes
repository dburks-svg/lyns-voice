# Normalize line endings so the toolchain is deterministic across machines.
# This repo's source is LF. Without this, a Windows checkout with
# core.autocrlf=true rewrites files to CRLF, which breaks esbuild's shebang
# stripping (scripts/inject.mjs) and yields "Invalid or unexpected token".
* text=auto eol=lf

# Shell/Node scripts and configs must stay LF regardless of detection.
*.mjs   text eol=lf
*.js    text eol=lf
*.ts    text eol=lf
*.mts   text eol=lf
*.cjs   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary assets: never apply EOL conversion.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.pdf   binary
